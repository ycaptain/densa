#!/usr/bin/env bash
set -euo pipefail

# git invokes commit-msg with the path of the real message file as $1
# (usually .git/COMMIT_EDITMSG, relative to the worktree root). This
# is the only hook stage where the in-flight commit message is
# readable: at pre-commit time git has not rewritten COMMIT_EDITMSG
# yet, so it still holds the PREVIOUS commit's message (TK-0038).
# AGENTS007 (operation-writes-within-scope) therefore runs here — the
# pre-commit hook runs every other rule and skips AGENTS007.
MSG_FILE="$1"
case "$MSG_FILE" in
    /*) ;;
    *) MSG_FILE="$PWD/$MSG_FILE" ;;
esac

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

# Make the in-repo densa package importable without installing it —
# same zero-setup posture as the sibling pre-commit hook:
#   git config core.hooksPath _system/hooks
# wires both hooks at once, no `pip install` required.
export PYTHONPATH="$REPO_ROOT/_system:${PYTHONPATH:-}"

# Hand the real message file to the validator; _commit_subject()
# prefers this env var over any other subject source.
export DENSA_COMMIT_MSG_FILE="$MSG_FILE"

# Prefer `python3` over `python` — macOS ships without `python` on
# the default PATH and some minimal Linux containers do too. Fall
# back to `python` only when `python3` is absent. If neither exists,
# print an actionable error rather than a cryptic `command not found`.
if command -v python3 >/dev/null 2>&1; then
    exec python3 -m densa --staged --select AGENTS007
fi
if command -v python >/dev/null 2>&1; then
    exec python -m densa --staged --select AGENTS007
fi
cat >&2 <<'EOF'
error: densa commit-msg hook requires python3 (>= 3.10).
       Install Python 3.10+ and retry.
       Temporary bypass for one commit: git commit --no-verify
       Permanent disable:                git config --unset core.hooksPath
EOF
exit 1
